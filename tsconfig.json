{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "jsx": "react-jsx",
    "rootDir": ".",
    "outDir": "dist",
    "typeRoots": ["./node_modules/@types", "./bitewise/types"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "backend-lib/**/*",
    "backend-api/**/*",
    "api/**/*",
    "src/vite-env.d.ts",
    "src/**/*",
    "bitewise/types/**/*"
  ]
}