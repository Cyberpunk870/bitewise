{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "jsx": "react-jsx",
    "rootDir": ".",                      // Ensure TS picks up all files correctly
    "outDir": "dist",
    "typeRoots": [
      "./node_modules/@types",
      "./bitewise/types"
    ],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "backend-lib/**/*",
    "backend-api/**/*",
    "api/**/*",
    "src/**/*",
    "vite-env.d.ts",
    "bitewise/types/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
