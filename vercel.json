{
  "version": 2,
  "builds": [
    {
      "src": "api/[[...all]].ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "backend-lib/**",
          "backend-api/**",
          "backend-lib/sa*.json"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/[...all].ts"
    },
    {
      "src": "/backend-api/(.*)",
      "dest": "api/[...all].ts"
    }
  ]
}
