{
  "version": 2,
  "builds": [
    {
      "src": "api/[...all].ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "backend-lib/**",
          "backend-api/**"
        ]
      }
    },
    {
      "src": "dist/index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/[...all].ts"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
