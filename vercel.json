{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "api/[[...all]].ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "backend-lib/**",
          "backend-api/**",
          "backend-lib/sa*.json"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/assets/(.*)",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "dest": "/assets/$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/[[...all]].ts"
    },
    {
      "src": "/backend-api/(.*)",
      "dest": "/api/[[...all]].ts"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
